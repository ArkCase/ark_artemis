#!/bin/bash

set -euo pipefail
. /.functions

#
# Init all the SSL-related stuff
#
init_ssl

#
# Add the ZooKeeper client options
#
. /usr/local/bin/zk-client-init

#
# Make sure the ZooKeeper chroot znode exists!
#
(
	export CURATOR_WRAPPER_JAR="/usr/local/bin/curator-wrapper.jar"
	export CURATOR_WRAPPER_CONF="/usr/local/etc/curator-wrapper.yaml"
	execute java "${ZOOKEEPER_SSL_CLIENT_OPTIONS_ARR[@]}" -jar "${CURATOR_WRAPPER_JAR}" -c "${CURATOR_WRAPPER_CONF}"
) || exit ${?}

mask_password()
{
	local PASSWORD="${1}"
	local HASH=""
	HASH="$(artemis mask --hash "${PASSWORD}" | awk '{ print $2 }' | tr -d '\n')" || return ${?}
	echo -n "ENC(${HASH})"
}

csv_to_list()
{
	tr ',' '\n' | sed -e '/^\s*$/d' | sort
}

add_user()
{
	local USERNAME="${1}"
	local PASSWORD="${2}"
	local FILE="${3}"
	local PASS=""
	PASS="$(mask_password "${PASSWORD}")" || fail "Failed to mask the password for the user [${USERNAME}] (rc=${?})"
	echo "${USERNAME} = ${PASS}" >> "${FILE}"
}

add_roles()
{
	local USERNAME="${1}"
	local ROLES="${2}"
	local FILE="${3}"

	local R=()
	local MEM=()
	readarray -t R < <(csv_to_list <<< "${ROLES}")
	for ROLE in "${R[@]}" ; do
		# get the list of members
		readarray -t MEM < <(csv_to_list < <(grep -E "^\s*${ROLE}\s*=" "${FILE}" | sed -e 's;^.*=;;g'))

		# add the user
		MEM+=("${USERNAME}")

		# sort alphabetically and uniquely
		MEM="$(echo -n "${MEM[@]}" | tr ' ' '\n' | sort -u | sed -e '/^\s*$/d' | tr '\n' ',' | sed -e 's;,$;;g')"

		# replace the existing roles line from the file
		sed -i -e "/^\s*${ROLE}\s*=/d" "${FILE}"

		echo "${ROLE} = ${MEM}" >> "${FILE}"
	done
}

set_or_default BASE_DIR "/app"
set_or_default CONF_DIR "${BASE_DIR}/conf"
set_or_default DATA_DIR "${BASE_DIR}/data"
set_or_default LOGS_DIR "${BASE_DIR}/logs"

# Fork into the application
set_or_default JAVA_MEM_ARGS "-XX:MinRAMPercentage=50.0 -XX:MaxRAMPercentage=80.0"
export JAVA_MEM_ARGS

require_dir_readwrite "${CONF_DIR}"
require_dir_readwrite "${DATA_DIR}"
require_dir_readwrite "${LOGS_DIR}"

export POD_HOSTNAME="$(hostname)"

# We need to XML-escape this value b/c it will get substituted into text values
export KEYSTORE="${JAVA_KEYSTORE}"
export KEYSTORE_PASSWORD="${JAVA_KEYSTORE_PASSWORD}"

set_or_default ARTEMIS_CLUSTER_PASSWORD "PBWaPfidc5Ko8kiof4338RvxZsWwwPOFtDMYF62IXDd5aWGJotw6QH2ARIozKPWE"
export ARTEMIS_CLUSTER_PASSWORD

# This is required at runtime
export CLUSTER_DOMAIN="$(get_cluster_domain)"

#
# Enable the new, environment-based authentication scheme
#
if [ "${ARTEMIS_NEW_USER_MODEL:-false}" == "true" ] ; then

	set_or_default ARTEMIS_ADMIN_USERNAME "admin"
	set_or_default ARTEMIS_ADMIN_PASSWORD ""
	[ -n "${ARTEMIS_ADMIN_PASSWORD}" ] || fail "Cannot have an empty administrator password"

	set_or_default ARTEMIS_ADMIN_ROLES "administrator"

	#
	# Render the user/roles files ...
	#
	USERS_FILE="${CONF_DIR}/artemis-users.properties"
	ROLES_FILE="${CONF_DIR}/artemis-roles.properties"

	:> "${USERS_FILE}" || fail "Failed to truncate the users file at [${USERS_FILE}]"
	:> "${ROLES_FILE}" || fail "Failed to truncate the roles file at [${ROLES_FILE}]"

	#
	# First, the administrator
	#
	add_user  "${ARTEMIS_ADMIN_USERNAME}" "${ARTEMIS_ADMIN_PASSWORD}" "${USERS_FILE}"
	add_roles "${ARTEMIS_ADMIN_USERNAME}" "${ARTEMIS_ADMIN_ROLES}"    "${ROLES_FILE}"

	# Now add the dynamic users
	for USERNAME in "${!ARTEMIS_USERNAME_@}" ; do
		[[ "${USERNAME}" =~ ^ARTEMIS_USERNAME_([0-9]+)$ ]] || continue
		NUM="${BASH_REMATCH[1]}"

		# Ignore empty usernames
		[ -n "${!USERNAME}" ] || continue

		# If there's no password for the user, we skip it
		PASSWORD="ARTEMIS_PASSWORD_${NUM}"
		[ -v "${PASSWORD}" ] || continue
		add_user "${!USERNAME}" "${!PASSWORD}" "${USERS_FILE}"

		# If there are no roles for the user, we skip'em
		ROLES="ARTEMIS_ROLES_${NUM}"
		[ -v "${ROLES}" ] || continue
		add_roles "${!USERNAME}" "${!ROLES}" "${ROLES_FILE}"
	done

	ok "Users generated"
	cat "${USERS_FILE}"
	ok "Roles generated"
	cat "${ROLES_FILE}"
	ok "Authentication configured"
fi

set_or_default JAVA_ARGS_APPEND
export JAVA_ARGS_APPEND

#
# Add the ZooKeeper SSL stuff
#
JAVA_ARGS_APPEND+=" ${ZOOKEEPER_SSL_CLIENT_OPTIONS}"

#
# Compute the SSL opts that Artemis needs
#
ARTEMIS_SSL_OPTS=()

# Key store
ARTEMIS_SSL_OPTS+=(
	-Dorg.apache.activemq.ssl.keyStore="${JAVA_KEYSTORE}"
	-Dorg.apache.activemq.ssl.keyStorePassword="${JAVA_KEYSTORE_PASSWORD}"
	-Dorg.apache.activemq.ssl.keyStoreType="${JAVA_KEYSTORE_TYPE}"
)
[ -n "${JAVA_KEYSTORE_PROVIDER:-}" ] && ARTEMIS_SSL_OPTS+=( -Dorg.apache.activemq.ssl.keyStoreProvider="${JAVA_KEYSTORE_PROVIDER}" )

# Trust store
ARTEMIS_SSL_OPTS+=(
	-Dorg.apache.activemq.ssl.trustStore="${JAVA_TRUSTSTORE}"
	-Dorg.apache.activemq.ssl.trustStorePassword="${JAVA_TRUSTSTORE_PASSWORD}"
	-Dorg.apache.activemq.ssl.trustStoreType="${JAVA_TRUSTSTORE_TYPE}"
)
[ -n "${JAVA_TRUSTSTORE_PROVIDER:-}" ] && ARTEMIS_SSL_OPTS+=( -Dorg.apache.activemq.ssl.trustStoreProvider="${JAVA_TRUSTSTORE_PROVIDER}" )

# JUL to Log4J?
LOG4J_JUL="$(find "${ARTEMIS_LIB}" -type f -name 'log4j-jul-*.jar' 2>&1)" || fail "Failed to check for the Log4J JUL bridge (rc=${?}): ${LOG4J_JUL}"
is_file_readable "${LOG4J_JUL}" && JAVA_ARGS_APPEND+=" -Djava.util.logging.manager=org.apache.logging.log4j.jul.LogManager"

#
# Add the flags!
#
JAVA_ARGS_APPEND+=" ${ARTEMIS_SSL_OPTS[@]}"
unset ARTEMIS_SSL_OPTS

CMD="${HOME_DIR}/bin/broker"
[ ${#} -lt 1 ] && set -- "run"
execute "${CMD}" "${@}"
